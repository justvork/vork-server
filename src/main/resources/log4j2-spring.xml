<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" properties="{}">
    <Properties>
        <!-- File logging enabled via VORK_FILE_LOGGING=true (development only) -->
        <Property name="file.logging.enabled" value="${env:VORK_FILE_LOGGING:-false}" />
        <Property name="log.dir" value="${env:VORK_LOG_DIR:-logs}" />
        <Property name="log.file" value="${log.dir}/vork.log" />
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%15.15t] [sid=%X{sessionUuid} eid=%X{eventId}] %-40.40c{1.} : %m%n%ex"/>
        </Console>

        <!-- File appender: truncates on startup, disabled by default -->
        <RollingFile name="File" fileName="${log.file}" filePattern="${log.dir}/vork.%i.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%15.15t] [sid=%X{sessionUuid} eid=%X{eventId}] %-40.40c{1.} : %m%n%ex"/>
            <Policies>
                <OnStartupTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="50MB" />
            </Policies>
            <DefaultRolloverStrategy max="10" />
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Application code at DEBUG; set to INFO in production via logging.level.sh.vork=INFO -->
        <Logger name="sh.vork" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <!-- Also write to file if VORK_FILE_LOGGING=true -->
            <AppenderRef ref="File" />
        </Logger>

        <!-- Everything else at INFO -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <!-- Also write to file if VORK_FILE_LOGGING=true -->
            <AppenderRef ref="File" />
        </Root>
    </Loggers>

</Configuration>
